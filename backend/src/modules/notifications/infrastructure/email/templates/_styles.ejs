<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background-color: #f4f6fb;
    font-family: "Avenir Next", Avenir, "Segoe UI", Helvetica, Arial, sans-serif;
    font-size: 15px;
    color: #07111f;
    -webkit-font-smoothing: antialiased;
  }
  .wrapper { width: 100%; padding: 40px 16px; }
  .card {
    max-width: 560px;
    margin: 0 auto;
    background: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #dde3ef;
  }
  .card-header {
    background: #ffffff;
    padding: 32px 40px 24px;
    border-bottom: 1px solid #eef1f7;
    text-align: center;
  }
  .logo { height: 36px; width: auto; display: inline-block; }
  .card-body { padding: 36px 40px; }
  .card-body p { color: #3a4557; line-height: 1.7; margin-bottom: 16px; }
  .event-name {
    font-size: 18px;
    font-weight: 700;
    color: #07111f;
    background: #f4f6fb;
    border-left: 3px solid #0f4cdb;
    padding: 14px 18px;
    border-radius: 6px;
    margin: 20px 0;
  }
  .btn {
    display: inline-block;
    margin-top: 8px;
    padding: 13px 28px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.01em;
  }
  .btn-primary { background-color: #0f4cdb; color: #ffffff !important; }
  .btn-danger  { background-color: #b40f17; color: #ffffff !important; }
  .btn-outline {
    background-color: #ffffff;
    color: #0f4cdb !important;
    border: 1.5px solid #0f4cdb;
  }
  .reason-box {
    background: #fff5f5;
    border: 1px solid #f1c6c8;
    border-radius: 6px;
    padding: 14px 18px;
    color: #7a0f15;
    font-size: 14px;
    line-height: 1.6;
    margin: 20px 0;
  }
  .reason-box strong { display: block; margin-bottom: 6px; color: #b40f17; }
  .divider { height: 1px; background: #eef1f7; margin: 28px 0; }
  .card-footer {
    background: #f9fafc;
    border-top: 1px solid #eef1f7;
    padding: 20px 40px;
    text-align: center;
  }
  .card-footer p { font-size: 12px; color: #8b95a8; line-height: 1.6; }
  .card-footer a { color: #0f4cdb; text-decoration: none; }
