<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= subject %></title>
  <%- include('_styles') %>
</head>
<body>
  <div class="wrapper">
    <div class="card">
      <div class="card-header">
        <img src="<%= logoUrl %>" alt="SwiftVote" class="logo" />
      </div>
      <div class="card-body">
        <p>Hi <%= recipientName %>,</p>
        <p>Your event could not be approved at this time.</p>
        <div class="event-name"><%= eventName %></div>
        <% if (rejectionReason) { %>
        <div class="reason-box">
          <strong>Reason for rejection</strong>
          <%= rejectionReason %>
        </div>
        <% } %>
        <p>You can update your event based on the feedback above and resubmit it for review.</p>
        <div class="divider"></div>
        <a href="<%= eventUrl %>" class="btn btn-outline">Edit &amp; resubmit</a>
      </div>
      <div class="card-footer">
        <p>This email was sent by SwiftVote. If you did not expect this, you can ignore it.</p>
        <p style="margin-top:6px"><a href="<%= frontendUrl %>">swiftvote.app</a></p>
      </div>
    </div>
  </div>
</body>
</html>
