generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SystemRole {
  SUPER_ADMIN
  NONE
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum EventStatus {
  DRAFT
  PENDING_APPROVAL
  REJECTED
  APPROVED
  NOMINATIONS_OPEN
  NOMINATIONS_CLOSED
  VOTING_SCHEDULED
  VOTING_LIVE
  VOTING_CLOSED
  ARCHIVED
}

enum EventRole {
  EVENT_OWNER
  EVENT_ADMIN
  MODERATOR
  ANALYST
}

enum MembershipStatus {
  ACTIVE
  REVOKED
}

enum NominationStatus {
  PENDING_REVIEW
  CONFIRMED
  REJECTED
}

enum VoteStatus {
  FREE
  PENDING_PAYMENT
  CONFIRMED
  FAILED
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  fullName     String
  systemRole   SystemRole  @default(NONE)
  status       UserStatus  @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  createdEvents           Event[]            @relation("EventCreator")
  approvedEvents          Event[]            @relation("EventApprover")
  rejectedEvents          Event[]            @relation("EventRejector")
  eventMemberships        EventMembership[]  @relation("MembershipUser")
  assignedMemberships     EventMembership[]  @relation("MembershipAssigner")
  submittedNominations    Nomination[]       @relation("NominationSubmitter")
  reviewedNominations     Nomination[]       @relation("NominationReviewer")
  contestantProfile       Contestant?
  magicLinkTokens         MagicLinkToken[]
}

model Event {
  id               String      @id @default(cuid())
  creatorUserId    String
  name             String
  slug             String      @unique
  description      String
  status           EventStatus @default(DRAFT)
  primaryFlyerUrl  String
  primaryFlyerKey  String
  bannerUrl        String?
  bannerKey        String?
  nominationStartAt              DateTime?
  nominationEndAt                DateTime?
  votingStartAt                  DateTime
  votingEndAt                    DateTime
  contestantsCanViewOwnVotes     Boolean   @default(false)
  contestantsCanViewLeaderboard  Boolean   @default(false)
  submittedAt      DateTime?
  approvedAt       DateTime?
  approvedByUserId String?
  rejectedAt       DateTime?
  rejectedByUserId String?
  rejectionReason  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  creator     User              @relation("EventCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)
  approvedBy  User?             @relation("EventApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  rejectedBy  User?             @relation("EventRejector", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  categories   EventCategory[]
  memberships  EventMembership[]
  nominations  Nomination[]
  contestants  Contestant[]
  votes        Vote[]

  @@index([creatorUserId, createdAt])
  @@index([status, submittedAt])
}

model EventCategory {
  id             String   @id @default(cuid())
  eventId        String
  name           String
  description    String
  votePriceMinor Int
  currency       String
  imageUrl       String?
  imageKey       String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  nominations  Nomination[]
  contestants  Contestant[]
  votes        Vote[]

  @@unique([eventId, name])
  @@index([eventId, sortOrder])
}

model EventMembership {
  id               String           @id @default(cuid())
  eventId          String
  userId           String
  role             EventRole
  status           MembershipStatus @default(ACTIVE)
  assignedByUserId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  event      Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User  @relation("MembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("MembershipAssigner", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId, role])
}

model Nomination {
  id               String           @id @default(cuid())
  eventId          String
  categoryId       String
  submittedByUserId String?
  submitterName    String
  submitterEmail   String
  nomineeName      String
  nomineeEmail     String?
  nomineePhone     String?
  nomineeImageUrl  String?
  nomineeImageKey  String?
  status           NominationStatus @default(PENDING_REVIEW)
  reviewedByUserId String?
  reviewedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  event       Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category    EventCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  submittedBy User?         @relation("NominationSubmitter", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  reviewedBy  User?         @relation("NominationReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  contestant  Contestant?

  @@index([eventId, status, createdAt])
  @@index([categoryId, status])
}

model Contestant {
  id           String   @id @default(cuid())
  eventId      String
  categoryId   String
  nominationId String   @unique
  userId       String?  @unique
  code         String
  name         String
  email        String?
  phone        String?
  imageUrl     String?
  imageKey     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event      Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category   EventCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  nomination Nomination    @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  user       User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  votes      Vote[]

  @@unique([eventId, code])
  @@index([eventId, categoryId])
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Vote {
  id             String     @id @default(cuid())
  eventId        String
  categoryId     String
  contestantId   String
  voterName      String
  voterEmail     String
  quantity       Int
  amountMinor    Int
  currency       String
  status         VoteStatus @default(FREE)
  transactionRef String?    @unique
  ipAddress      String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  event      Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category   EventCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  contestant Contestant    @relation(fields: [contestantId], references: [id], onDelete: Cascade)

  @@index([eventId, categoryId])
  @@index([contestantId])
  @@index([voterEmail])
  @@index([eventId, status, createdAt])
}
