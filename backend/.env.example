NODE_ENV=development
APP_NAME=swiftvote-api
APP_VERSION=0.1.0
PORT=3001
API_PREFIX=api
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://swiftvote:swiftvote@localhost:5432/swiftvote?schema=public
JWT_ACCESS_SECRET=replace-with-a-strong-access-secret
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_REFRESH_COOKIE_NAME=swiftvote_refresh_token
AWS_S3_BUCKET_NAME=swiftvote-assets
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_SIGNED_URL_TTL_SECONDS=900
SUPER_ADMIN_EMAIL=admin@swiftvote.app
SUPER_ADMIN_PASSWORD=change-me-now
SUPER_ADMIN_FULL_NAME=SwiftVote Super Admin

# ─── Email / Resend ──────────────────────────────────────────────────────────
# Resend requires an API key and a verified sending domain for production.
RESEND_API_KEY=
RESEND_FROM=SwiftVote <no-reply@swiftvote.app>
EMAIL_FROM=SwiftVote <no-reply@swiftvote.app>

# ─── Email / SMTP fallback ───────────────────────────────────────────────────
# Used only when RESEND_API_KEY is empty.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ─── Payment provider switch ─────────────────────────────────────────────────
# true keeps the current Paystack flow; false uses the JuniPay-ready OTP flow.
USE_PAYSTACK=false
NEXT_PUBLIC_USE_PAYSTACK=false

# ─── SMS / Arkesel ───────────────────────────────────────────────────────────
# Arkesel docs use https://sms.arkesel.com/api/v2/sms/send for sends.
SMS_ENABLED=false
SMS_SENDER_ID=SwiftVote
SMS_API_KEY=
SMS_BASE_URL=https://sms.arkesel.com/api/v2
